<Window x:Class="OpenSteps.App.ScreenshotRedactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Screenshot" Height="760" Width="1080" MinHeight="560" MinWidth="760"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1" CornerRadius="18" Padding="14" Margin="18,16,18,0">
            <Border.Effect>
                <DropShadowEffect Color="#9DB4BE" BlurRadius="16" ShadowDepth="2" Opacity="0.14" />
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tool" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button x:Name="PixelateToolButton" Content="Pixel" ToolTip="Pixelate"
                            Click="PixelateTool_Click"
                            Padding="12,6" Margin="0,0,8,0" FontWeight="SemiBold" />
                    <Button x:Name="RedCircleToolButton" Content="Circle" ToolTip="Draw red circle"
                            Click="RedCircleTool_Click"
                            Padding="12,6" Margin="0,0,18,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#xE7A7;" ToolTip="Undo" Click="Undo_Click"
                            Style="{StaticResource IconButton}" Margin="0,0,8,0" />
                    <Button Content="&#xE894;" ToolTip="Clear all" Click="ClearAll_Click"
                            Style="{StaticResource IconButton}" Margin="0,0,8,0" />
                    <Button Content="&#xE74E;" ToolTip="Save" Click="Save_Click"
                            Style="{StaticResource PrimaryIconButton}" Margin="0,0,8,0" />
                    <Button Content="&#xE711;" ToolTip="Cancel" Click="Cancel_Click"
                            Style="{StaticResource IconButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="18" Background="#DCEBF0" BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1" CornerRadius="18" Padding="12">
            <Border.Effect>
                <DropShadowEffect Color="#9DB4BE" BlurRadius="18" ShadowDepth="2" Opacity="0.12" />
            </Border.Effect>
            <Grid x:Name="ImageHost" Background="#F8FCFD">
                <Image x:Name="ScreenshotImage" Stretch="Uniform" />
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent"
                        MouseDown="OverlayCanvas_MouseDown"
                        MouseMove="OverlayCanvas_MouseMove"
                        MouseUp="OverlayCanvas_MouseUp" />
            </Grid>
        </Border>
    </Grid>
</Window>

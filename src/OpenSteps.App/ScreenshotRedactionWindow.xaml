<Window x:Class="OpenSteps.App.ScreenshotRedactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Screenshot" Height="760" Width="1080" MinHeight="560" MinWidth="760"
        Background="#111827">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#D9DEE8" BorderThickness="0,0,0,1" Padding="14">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Pixelate" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,18,0" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Undo" Click="Undo_Click" Padding="12,6" Margin="0,0,8,0" />
                    <Button Content="Clear All" Click="ClearAll_Click" Padding="12,6" Margin="0,0,8,0" />
                    <Button Content="Save" Click="Save_Click" Padding="16,6" Margin="0,0,8,0" FontWeight="SemiBold" />
                    <Button Content="Cancel" Click="Cancel_Click" Padding="12,6" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid x:Name="ImageHost" Grid.Row="1" Margin="18" Background="#0B1020">
            <Image x:Name="ScreenshotImage" Stretch="Uniform" />
            <Canvas x:Name="OverlayCanvas"
                    Background="Transparent"
                    MouseDown="OverlayCanvas_MouseDown"
                    MouseMove="OverlayCanvas_MouseMove"
                    MouseUp="OverlayCanvas_MouseUp" />
        </Grid>
    </Grid>
</Window>

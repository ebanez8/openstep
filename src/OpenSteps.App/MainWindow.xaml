<Window x:Class="OpenSteps.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenSteps" Height="760" Width="1120" MinHeight="620" MinWidth="920"
        Background="#F5F7FA">
    <Grid>
        <Grid x:Name="HomePanel" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" MaxWidth="720">
                <TextBlock Text="OpenSteps" FontSize="44" FontWeight="SemiBold" Foreground="#151A24" />
                <TextBlock Text="Record desktop workflows into step-by-step guides."
                           Margin="0,10,0,0" FontSize="20" Foreground="#4B5565" />
                <TextBlock Text="OpenSteps records screenshots and click metadata locally. It does not upload anything."
                           Margin="0,28,0,0" TextWrapping="Wrap" FontSize="14" Foreground="#5F6B7A" />

                <StackPanel Orientation="Horizontal" Margin="0,34,0,0">
                    <Button Content="Start Recording" Click="StartRecording_Click"
                            Padding="24,12" FontSize="16" FontWeight="SemiBold" />
                    <Button Content="Capture Test Step" Click="CaptureTestStep_Click"
                            Margin="14,0,0,0" Padding="18,12" FontSize="16" />
                    <Button Content="Open Previous Session" IsEnabled="False"
                            Margin="14,0,0,0" Padding="18,12" FontSize="16" />
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="MVP: global click capture, screenshots, editable steps, and Markdown export."
                       Foreground="#6B7280" />
        </Grid>

        <Grid x:Name="EditorPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="White" BorderBrush="#D9DEE8" BorderThickness="0,0,0,1" Padding="28,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBox x:Name="SessionTitleBox"
                                 FontSize="26" FontWeight="SemiBold"
                                 BorderThickness="0" Background="Transparent"
                                 TextChanged="SessionTitleBox_TextChanged" />
                        <TextBlock x:Name="SessionSummaryText" Margin="2,6,0,0" Foreground="#5F6B7A" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Record More" Click="StartRecording_Click" Padding="14,9" />
                        <Button Content="Export Markdown" Click="ExportMarkdown_Click"
                                Margin="10,0,0,0" Padding="16,9" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="28" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="StepsList" ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#D9DEE8" BorderThickness="1"
                                    CornerRadius="6" Margin="0,0,0,18" Padding="18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="280" Height="170" Background="#EEF2F7"
                                            BorderBrush="#CBD5E1" BorderThickness="1">
                                        <Image Source="{Binding ScreenshotPath}" Stretch="Uniform" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding Index, StringFormat=Step {0}}"
                                                       FontWeight="SemiBold" Foreground="#3B4454"
                                                       Margin="0,0,14,0" />
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="Up" Click="MoveStepUp_Click" Margin="0,0,6,0" Padding="8,4" />
                                                <Button Content="Down" Click="MoveStepDown_Click" Margin="0,0,6,0" Padding="8,4" />
                                                <Button Content="Delete" Click="DeleteStep_Click" Padding="8,4" />
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBox Text="{Binding UserTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" />
                                        <TextBox Text="{Binding UserDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,10,0,0" MinHeight="72" TextWrapping="Wrap"
                                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                                        <Expander Header="Metadata" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding MetadataSummary}" TextWrapping="Wrap"
                                                       FontFamily="Consolas" FontSize="12" Foreground="#4B5565" />
                                        </Expander>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

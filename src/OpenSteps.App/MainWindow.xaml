<Window x:Class="OpenSteps.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenSteps" Height="82" Width="760" MinHeight="82" MinWidth="760"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True">
    <Window.Resources>
        <Style x:Key="PillIconButton" TargetType="Button">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Foreground" Value="#47545B" />
            <Setter Property="Background" Value="#EDF6F9" />
            <Setter Property="BorderBrush" Value="#DDE9EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E4EEF3" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D4E1E8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DCE9EF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryPillIconButton" TargetType="Button" BasedOn="{StaticResource PillIconButton}">
            <Setter Property="Foreground" Value="#33414A" />
            <Setter Property="Background" Value="#DCE9EF" />
            <Setter Property="BorderBrush" Value="#C9D9E1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D6E5EC" />
                    <Setter Property="BorderBrush" Value="#C2D4DD" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostPillIconButton" TargetType="Button" BasedOn="{StaticResource PillIconButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#63727B" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="HomePanel" Margin="12">
            <Border Background="#EEF8FB" BorderBrush="#D9E8EE"
                    BorderThickness="1" CornerRadius="30" Padding="12,8"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#8FA7B2" BlurRadius="26" ShadowDepth="5" Opacity="0.34" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE700;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Move" PreviewMouseLeftButtonDown="MoveControl_MouseLeftButtonDown"
                            Style="{StaticResource GhostPillIconButton}" Cursor="SizeAll" />
                    <TextBlock Text="OpenSteps" Foreground="#1E2B35" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="6,0,18,0" />

                    <TextBlock Text="Screenshot mode" Foreground="#52636B"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding ScreenshotModeOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Mode"
                              SelectedValue="{Binding ScreenshotMode, Mode=TwoWay}"
                              Width="136" Height="34"
                              VerticalContentAlignment="Center"
                              Margin="0,0,14,0"
                              ToolTip="Full desktop captures all visible monitors. Active window only captures the foreground window when possible and falls back to full desktop if needed." />

                    <Button x:Name="StartRecordingButton" Content="&#xE768;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Start recording" Click="StartRecording_Click"
                            Style="{StaticResource PrimaryPillIconButton}" />
                    <Button x:Name="PauseRecordingButton" Content="&#xE769;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Pause recording" Click="PauseRecording_Click"
                            Style="{StaticResource PrimaryPillIconButton}" Margin="10,0,0,0"
                            Visibility="Collapsed" />
                    <Button x:Name="StopRecordingButton" Content="&#xE71A;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Stop recording" Click="StopRecording_Click"
                            Style="{StaticResource PrimaryPillIconButton}" Margin="10,0,0,0"
                            Visibility="Collapsed" />
                    <Button Content="&#xE722;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Capture test step" Click="CaptureTestStep_Click"
                            Style="{StaticResource PillIconButton}" Margin="10,0,0,0" />
                    <Button Content="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Saved sessions" Click="OpenPreviousSession_Click"
                            Style="{StaticResource PillIconButton}" Margin="10,0,0,0" />
                    <TextBlock x:Name="RecordingStatusText" Foreground="#52636B"
                               VerticalAlignment="Center" Margin="16,0,14,0" />
                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                            ToolTip="Close" Click="Close_Click"
                            Style="{StaticResource GhostPillIconButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

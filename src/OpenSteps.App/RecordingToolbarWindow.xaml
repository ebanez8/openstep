<Window x:Class="OpenSteps.App.RecordingToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSteps Recording" Width="520" Height="76"
        WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        ShowInTaskbar="False" Background="White"
        AllowsTransparency="True" WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        LocationChanged="Window_LocationChanged"
        SourceInitialized="Window_SourceInitialized">
    <Border Background="#1C1C25" BorderBrush="#2A2B38" BorderThickness="1"
            CornerRadius="34" Padding="14,10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.28" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="OpenSteps" Foreground="#E7E8EE" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0,18,0" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="34" Height="34" CornerRadius="17" Background="#2B2C38"
                        BorderBrush="#3B3C49" BorderThickness="1" Margin="0,0,10,0">
                    <Ellipse Width="12" Height="12" Fill="#D92D20" />
                </Border>
                <TextBlock x:Name="StatusText" Foreground="#D9DBE4" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="PauseButton" Content="Pause" Click="PauseButton_Click"
                        Padding="13,7" Foreground="#F2F3F7" Background="#30313E"
                        BorderBrush="#3D3E4D" />
                <Button Content="Stop" Click="StopButton_Click" Margin="8,0,10,0"
                        Padding="13,7" Foreground="#F2F3F7" Background="#30313E"
                        BorderBrush="#3D3E4D" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="OpenSteps.App.RecordingToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSteps Recording" Width="380" Height="72"
        WindowStyle="ToolWindow" ResizeMode="NoResize" Topmost="True"
        ShowInTaskbar="False" Background="White">
    <Border BorderBrush="#D9DEE8" BorderThickness="1" Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12" Fill="#D92D20" Margin="0,0,10,0" />
                <TextBlock x:Name="StatusText" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="PauseButton" Content="Pause" Click="PauseButton_Click" Padding="10,5" />
                <Button Content="Stop" Click="StopButton_Click" Margin="8,0,0,0" Padding="10,5" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

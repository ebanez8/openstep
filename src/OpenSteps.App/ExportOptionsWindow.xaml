<Window x:Class="OpenSteps.App.ExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export options" Width="540" Height="420" MinWidth="460" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Border Style="{StaticResource Card}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Export guide"
                               Style="{StaticResource DisplayText}"
                               FontSize="20" />
                    <TextBlock Text="Choose which guide files to create. Screenshots are included alongside them in an /images folder."
                               Style="{StaticResource SubtleText}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,18" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource Card}"
                            Background="{StaticResource SubtleSurfaceBrush}"
                            Padding="16,14">
                        <StackPanel>
                            <CheckBox x:Name="MarkdownCheckBox" IsChecked="True">
                                <StackPanel>
                                    <TextBlock Text="Markdown (.md)" FontWeight="SemiBold" />
                                    <TextBlock Text="Portable, version-controllable, renders in most docs tools."
                                               Style="{StaticResource SubtleText}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </CheckBox>
                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderSoftBrush}"
                                       Margin="0,12,0,12" />
                            <CheckBox x:Name="HtmlCheckBox" IsChecked="True">
                                <StackPanel>
                                    <TextBlock Text="HTML (.html)" FontWeight="SemiBold" />
                                    <TextBlock Text="Self-contained page that opens in any browser."
                                               Style="{StaticResource SubtleText}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,22,0,0">
                <Button Content="Cancel"
                        Click="Cancel_Click"
                        Padding="18,0" Height="34" />
                <Button Content="Continue"
                        Click="Continue_Click"
                        Margin="10,0,0,0"
                        Padding="18,0" Height="34"
                        Style="{StaticResource PrimaryActionButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

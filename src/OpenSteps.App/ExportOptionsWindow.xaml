<Window x:Class="OpenSteps.App.ExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Options" Width="420" Height="250" MinWidth="380" MinHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="18" Padding="20"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource BorderSoftBrush}"
            BorderThickness="1"
            CornerRadius="18">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Click="Cancel_Click" Padding="16,0" Height="34" />
                <Button Content="Continue" Click="Continue_Click"
                        Margin="10,0,0,0" Padding="16,0" Height="34"
                        Style="{StaticResource PrimaryActionButton}" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Export files"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Choose the guide files to create."
                           Margin="0,6,0,16"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <CheckBox x:Name="MarkdownCheckBox"
                          Content="Markdown (.md)"
                          IsChecked="True"
                          Margin="0,0,0,10" />
                <CheckBox x:Name="HtmlCheckBox"
                          Content="HTML (.html)"
                          IsChecked="True"
                          Margin="0,0,0,10" />
                <TextBlock Text="Both formats include relative screenshot links and an images folder."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="24,2,0,0" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>

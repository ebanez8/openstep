<Window x:Class="OpenSteps.App.MarkdownPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Markdown Preview" Width="860" Height="640" MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copy Markdown" Click="CopyMarkdown_Click"
                    Padding="16,0" Height="34"
                    Style="{StaticResource PrimaryActionButton}" />
            <Button Content="Close" Click="Close_Click"
                    Margin="10,0,0,0" Padding="16,0" Height="34" />
        </StackPanel>

        <Border Background="White"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1">
            <WebBrowser x:Name="PreviewBrowser" />
        </Border>
    </DockPanel>
</Window>

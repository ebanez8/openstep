<Window x:Class="OpenSteps.App.SessionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenSteps.App"
        Title="Saved guides" Width="820" Height="560" MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <local:FileImageConverter x:Key="FileImageConverter" />
    </Window.Resources>
    <DockPanel>

        <!--  ─────────── Header ────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Saved guides" Style="{StaticResource DisplayText}" FontSize="20" />
                    <TextBlock Text="Open a previous capture or browse the folder on disk."
                               Style="{StaticResource SubtleText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Button Grid.Column="1"
                        Click="OpenFolder_Click"
                        ToolTip="Open sessions folder"
                        Padding="14,0" Height="34"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Show in Explorer" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  ─────────── Empty state ──────────────────────────────── -->
        <Grid>
            <StackPanel x:Name="EmptyText"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <Border Width="56" Height="56"
                        Background="{StaticResource SoftSurfaceBrush}"
                        CornerRadius="14"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="22"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="No saved guides yet"
                           Style="{StaticResource HeadingText}"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,4" />
                <TextBlock Text="Capture a recording and it will appear here."
                           Style="{StaticResource SubtleText}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!--  ─────────── Session grid ─────────────────────────── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,20,12,20">
                <ListBox x:Name="SessionsList"
                         ItemsSource="{Binding Sessions}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding SessionGridColumns}" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="SessionCard"
                                    Background="{StaticResource PanelBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Margin="0,0,12,12"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="SessionCard_MouseLeftButtonUp">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="SessionCardShadow"
                                                      Color="#1F2937"
                                                      BlurRadius="14"
                                                      ShadowDepth="2"
                                                      Opacity="0.05" />
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderEmphasisBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="148" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Thumbnail  -->
                                    <Border Grid.Row="0"
                                            Background="{StaticResource SoftSurfaceBrush}"
                                            CornerRadius="11,11,0,0"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource FileImageConverter}}"
                                                   Stretch="UniformToFill" />
                                            <Button Content="&#xE74D;"
                                                    ToolTip="Delete guide"
                                                    Click="Delete_Click"
                                                    Style="{StaticResource IconButton}"
                                                    Background="#CCFFFFFF"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="8" />
                                        </Grid>
                                    </Border>

                                    <!--  Metadata  -->
                                    <StackPanel Grid.Row="1" Margin="16,14,16,16">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12">
                                                <Run Text="{Binding StepCount, Mode=OneWay}" />
                                                <Run Text=" steps" />
                                            </TextBlock>
                                            <TextBlock Text=" · "
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:MMM d\, yyyy}}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>

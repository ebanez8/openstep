<Window x:Class="OpenSteps.App.SessionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenSteps.App"
        Title="Saved OpenSteps Sessions" Width="760" Height="520" MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <local:FileImageConverter x:Key="FileImageConverter" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1" CornerRadius="18" Padding="18" Margin="18,16,18,0">
            <Border.Effect>
                <DropShadowEffect Color="#9DB4BE" BlurRadius="16" ShadowDepth="2" Opacity="0.14" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Saved Sessions" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Open a previous guide or browse the saved session files."
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1" Click="OpenFolder_Click"
                        ToolTip="Open sessions folder"
                        Style="{StaticResource PrimaryActionButton}"
                        Padding="14,0" Height="34"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="Files" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Margin="18">
            <TextBlock x:Name="EmptyText" Text="No saved sessions yet." Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
            <ListBox x:Name="SessionsList" ItemsSource="{Binding Sessions}" BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" CornerRadius="16"
                                Padding="12" Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect Color="#9DB4BE" BlurRadius="12" ShadowDepth="2" Opacity="0.1" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="82" Height="58" Background="{StaticResource SoftSurfaceBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1"
                                        CornerRadius="12" ClipToBounds="True">
                                    <Image Source="{Binding ThumbnailPath, Converter={StaticResource FileImageConverter}}" Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="10,0,14,0">
                                    <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="16" FontWeight="SemiBold" Padding="8,4" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="2,6,0,0">
                                        <Run Text="{Binding StepCount}" />
                                        <Run Text=" steps  Updated " />
                                        <Run Text="{Binding UpdatedAt, StringFormat={}{0:g}}" />
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="&#xE8E5;" ToolTip="Open session" Click="Open_Click"
                                            Style="{StaticResource PrimaryIconButton}" Margin="0,0,6,0" />
                                    <Button Content="&#xE8AC;" ToolTip="Rename session" Click="Rename_Click"
                                            Style="{StaticResource IconButton}" Margin="0,0,6,0" />
                                    <Button Content="&#xE74D;" ToolTip="Delete session" Click="Delete_Click"
                                            Style="{StaticResource IconButton}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>

<Window x:Class="OpenSteps.App.SessionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenSteps.App"
        Title="Saved OpenSteps Sessions" Width="760" Height="520" MinWidth="620" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <local:FileImageConverter x:Key="FileImageConverter" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1" CornerRadius="18" Padding="18" Margin="18,16,18,0">
            <Border.Effect>
                <DropShadowEffect Color="#9DB4BE" BlurRadius="16" ShadowDepth="2" Opacity="0.14" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Saved Sessions" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Open a previous guide or browse the saved session files."
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <Button Grid.Column="1" Click="OpenFolder_Click"
                        ToolTip="Open sessions folder"
                        Style="{StaticResource PrimaryActionButton}"
                        Padding="14,0" Height="34"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="Files" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Margin="18">
            <TextBlock x:Name="EmptyText" Text="No saved sessions yet." Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
            <ListBox x:Name="SessionsList" ItemsSource="{Binding Sessions}"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding SessionGridColumns}" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="SessionCard"
                                Background="{StaticResource PanelBackgroundBrush}"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1" CornerRadius="16"
                                Padding="12" Margin="0,0,14,14"
                                MinHeight="230"
                                Cursor="Hand"
                                MouseLeftButtonUp="SessionCard_MouseLeftButtonUp"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="SessionCardShadow"
                                                  Color="#9DB4BE" BlurRadius="12"
                                                  ShadowDepth="2" Opacity="0.1" />
                            </Border.Effect>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SessionCard"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.015" Duration="0:0:0.14" />
                                            <DoubleAnimation Storyboard.TargetName="SessionCard"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.015" Duration="0:0:0.14" />
                                            <DoubleAnimation Storyboard.TargetName="SessionCardShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.18" Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SessionCard"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="SessionCard"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="SessionCardShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.1" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Background="{StaticResource SoftSurfaceBrush}"
                                        BorderBrush="{StaticResource BorderSoftBrush}"
                                        BorderThickness="1" CornerRadius="12"
                                        ClipToBounds="True" MinHeight="132">
                                    <Grid>
                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource FileImageConverter}}"
                                               Stretch="UniformToFill" />
                                        <Button Content="&#xE74D;" ToolTip="Delete session"
                                                Click="Delete_Click"
                                                Style="{StaticResource IconButton}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="8" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0">
                                            <Run Text="{Binding StepCount}" />
                                            <Run Text=" steps" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>

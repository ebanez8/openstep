<Window x:Class="OpenSteps.App.ExportResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export complete" Width="660" Height="440" MinWidth="560" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="20" Style="{StaticResource Card}" Padding="24">
        <DockPanel>

            <!--  Footer actions  -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Close"
                        Click="Close_Click"
                        Padding="18,0" Height="34" />
                <Button Click="CopyPath_Click"
                        Margin="10,0,0,0"
                        Padding="16,0" Height="34">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Copy path" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Click="OpenFolder_Click"
                        Margin="10,0,0,0"
                        Padding="18,0" Height="34"
                        Style="{StaticResource PrimaryActionButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Open folder" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!--  Header  -->
            <StackPanel DockPanel.Dock="Top">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36"
                            Background="#E7F7EE"
                            CornerRadius="10"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE73E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Export complete" Style="{StaticResource DisplayText}" FontSize="20" />
                        <TextBlock Text="Your guide files are ready."
                                   Style="{StaticResource SubtleText}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!--  Body  -->
            <Grid Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="CREATED FILES" Style="{StaticResource CaptionText}" Margin="0,0,0,6" />
                    <Border Background="{StaticResource SubtleSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="2">
                        <TextBox x:Name="PathText"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 MinHeight="72"
                                 MaxHeight="100"
                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                 FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="WARNINGS" Style="{StaticResource CaptionText}" />
                        <TextBlock x:Name="WarningsCount"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource WarningBrush}"
                                   Margin="6,0,0,0" />
                    </StackPanel>
                    <Border Background="{StaticResource SubtleSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSoftBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="2">
                        <TextBox x:Name="WarningsTextBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="100"
                                 FontFamily="Cascadia Mono, Consolas, monospace"
                                 FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    </Border>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>

<Window x:Class="OpenSteps.App.CropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crop Screenshot" Width="980" Height="720" MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Reset Selection" Click="ResetSelection_Click"
                    Padding="16,0" Height="34" />
            <Button Content="Apply" Click="Apply_Click"
                    Margin="10,0,0,0" Padding="16,0" Height="34"
                    Style="{StaticResource PrimaryActionButton}" />
            <Button Content="Cancel" Click="Cancel_Click"
                    Margin="10,0,0,0" Padding="16,0" Height="34" />
        </StackPanel>

        <Border Background="{StaticResource SoftSurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True">
            <Grid x:Name="ImageHost">
                <Image x:Name="ScreenshotImage"
                       Stretch="Uniform" />
                <Canvas x:Name="OverlayCanvas"
                        Background="Transparent"
                        MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
                        MouseMove="OverlayCanvas_MouseMove"
                        MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">
                    <Rectangle x:Name="SelectionRectangle"
                               Visibility="Collapsed"
                               Stroke="{StaticResource AccentBrush}"
                               StrokeThickness="2"
                               Fill="#3311162A" />
                </Canvas>
            </Grid>
        </Border>
    </DockPanel>
</Window>

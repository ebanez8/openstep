<Window x:Class="OpenSteps.App.SessionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenSteps.App"
        Title="OpenSteps" Width="1160" Height="780" MinWidth="940" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <local:FileImageConverter x:Key="FileImageConverter" />

        <!--  Small "chip" used for action-type pills.  -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="9,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!--  ─────────── Header bar ─────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#xE72B;"
                        ToolTip="Back to recorder"
                        Click="BackToRecorder_Click"
                        Style="{StaticResource IconButton}"
                        Width="36" Height="36"
                        Margin="0,0,16,0" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="GUIDE TITLE"
                               Style="{StaticResource CaptionText}"
                               Margin="2,0,0,2" />
                    <TextBox x:Name="SessionTitleBox"
                             FontSize="20"
                             FontWeight="SemiBold"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Padding="2,0"
                             MinHeight="30"
                             ToolTip="Guide title"
                             TextChanged="SessionTitleBox_TextChanged" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE7C8;"
                            ToolTip="Record more steps"
                            Click="RecordMore_Click"
                            Style="{StaticResource IconButton}"
                            Width="36" Height="36" />
                    <Button Content="&#xE74E;"
                            ToolTip="Save"
                            Click="SaveSession_Click"
                            Style="{StaticResource IconButton}"
                            Width="36" Height="36"
                            Margin="6,0,0,0" />
                    <Button Click="ExportMarkdown_Click"
                            Margin="14,0,0,0"
                            Padding="16,0"
                            Height="36"
                            Style="{StaticResource PrimaryActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEDE1;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="Export guide" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  ─────────── Step list ─────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <Grid>
                <!--  Empty state (visible when there are no steps; controlled in code-behind via RefreshSteps)  -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,140,0,0"
                            Visibility="Collapsed">
                    <Border Width="56" Height="56"
                            Background="{StaticResource SoftSurfaceBrush}"
                            CornerRadius="14"
                            HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9F9;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="No steps yet"
                               Style="{StaticResource HeadingText}"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,4" />
                    <TextBlock Text="Click ‘Record more steps’ to start capturing."
                               Style="{StaticResource SubtleText}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <ItemsControl x:Name="StepsList"
                              ItemsSource="{Binding Steps}"
                              Padding="28,24,28,32">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Step rail with number badge and connecting line  -->
                                <Grid Grid.Column="0">
                                    <Rectangle Width="2"
                                               Fill="{StaticResource BorderSoftBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Stretch"
                                               Margin="0,8,0,0" />
                                    <Border Width="34" Height="34"
                                            Background="{StaticResource PanelBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Index}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!--  Step card  -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource PanelBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1F2937" BlurRadius="14" ShadowDepth="2" Opacity="0.05" />
                                    </Border.Effect>

                                    <Grid Margin="18">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Header row: chip + spacer + action buttons  -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Style="{StaticResource Chip}">
                                                    <TextBlock Text="{Binding ActionType}" Style="{StaticResource ChipText}" />
                                                </Border>
                                                <TextBlock Text="{Binding Index, StringFormat=Step {0}}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#xE70F;"
                                                        ToolTip="Edit screenshot"
                                                        Click="EditScreenshot_Click"
                                                        Style="{StaticResource IconButton}" />
                                                <Button Content="&#xE722;"
                                                        ToolTip="Capture new screenshot for this step"
                                                        Click="CaptureStepScreenshot_Click"
                                                        Style="{StaticResource IconButton}"
                                                        Margin="4,0,0,0" />
                                                <Rectangle Width="1" Height="20"
                                                           Fill="{StaticResource BorderSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0" />
                                                <Button Content="&#xECC8;"
                                                        ToolTip="Insert manual step below"
                                                        Click="InsertManualStepBelow_Click"
                                                        Style="{StaticResource IconButton}" />
                                                <Button Content="&#xE74A;"
                                                        ToolTip="Move up"
                                                        Click="MoveStepUp_Click"
                                                        Style="{StaticResource IconButton}"
                                                        Margin="4,0,0,0" />
                                                <Button Content="&#xE74B;"
                                                        ToolTip="Move down"
                                                        Click="MoveStepDown_Click"
                                                        Style="{StaticResource IconButton}"
                                                        Margin="4,0,0,0" />
                                                <Rectangle Width="1" Height="20"
                                                           Fill="{StaticResource BorderSoftBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0" />
                                                <Button Content="&#xE74D;"
                                                        ToolTip="Delete step"
                                                        Click="DeleteStep_Click"
                                                        Style="{StaticResource DangerIconButton}" />
                                            </StackPanel>
                                        </Grid>

                                        <!--  Body: screenshot + text  -->
                                        <Grid Grid.Row="1" Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="296" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="284" Height="176"
                                                    Background="{StaticResource SoftSurfaceBrush}"
                                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top">
                                                <Grid>
                                                    <Image Source="{Binding EffectiveScreenshotPath, Converter={StaticResource FileImageConverter}}"
                                                           Stretch="Uniform" />

                                                    <!--  Redacted badge  -->
                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="10"
                                                            Background="{StaticResource AccentBrush}"
                                                            CornerRadius="999"
                                                            Padding="8,3">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasRedactions}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE890;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,5,0" />
                                                            <TextBlock Text="Redacted"
                                                                       FontSize="10.5"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Button Content="&#xE890;"
                                                            ToolTip="View screenshot"
                                                            Click="ViewScreenshot_Click"
                                                            Style="{StaticResource IconButton}"
                                                            Background="#CCFFFFFF"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,10,10" />
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Column="1" Margin="18,0,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBox Grid.Row="0"
                                                         Text="{Binding UserTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         TextChanged="StepTextChanged"
                                                         FontSize="16"
                                                         FontWeight="SemiBold" />

                                                <TextBox Grid.Row="1"
                                                         Text="{Binding UserDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         TextChanged="StepTextChanged"
                                                         Margin="0,10,0,0"
                                                         MinHeight="92"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto" />
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>

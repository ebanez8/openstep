<Window x:Class="OpenSteps.App.SessionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenSteps" Width="1120" Height="760" MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#D9DEE8" BorderThickness="0,0,0,1" Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBox x:Name="SessionTitleBox"
                             FontSize="26" FontWeight="SemiBold"
                             BorderThickness="0" Background="Transparent"
                             TextChanged="SessionTitleBox_TextChanged" />
                    <TextBlock x:Name="SessionSummaryText" Margin="2,6,0,0" Foreground="#5F6B7A" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Record More" Click="RecordMore_Click" Padding="14,9" />
                    <Button Content="Save Session" Click="SaveSession_Click"
                            Margin="10,0,0,0" Padding="14,9" />
                    <Button Content="Export Markdown" Click="ExportMarkdown_Click"
                            Margin="10,0,0,0" Padding="16,9" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="28" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="StepsList" ItemsSource="{Binding Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#D9DEE8" BorderThickness="1"
                                CornerRadius="6" Margin="0,0,0,18" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="280" Height="170" Background="#EEF2F7"
                                        BorderBrush="#CBD5E1" BorderThickness="1">
                                    <Grid>
                                        <Image Source="{Binding EffectiveScreenshotPath}" Stretch="Uniform" />
                                        <TextBlock Text="Redacted"
                                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                                   Margin="8" Padding="7,3" Background="#111827"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRedactions}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Content="View" Click="ViewScreenshot_Click"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Margin="0,0,8,8" Padding="8,4" />
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Index, StringFormat=Step {0}}"
                                                   FontWeight="SemiBold" Foreground="#3B4454"
                                                   Margin="0,0,14,0" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="Edit screenshot" Click="EditScreenshot_Click" Margin="0,0,6,0" Padding="8,4" />
                                            <Button Content="Up" Click="MoveStepUp_Click" Margin="0,0,6,0" Padding="8,4" />
                                            <Button Content="Down" Click="MoveStepDown_Click" Margin="0,0,6,0" Padding="8,4" />
                                            <Button Content="Delete" Click="DeleteStep_Click" Padding="8,4" />
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBox Text="{Binding UserTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding UserDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,10,0,0" MinHeight="72" TextWrapping="Wrap"
                                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                                    <Expander Header="Capture debug/status" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding MetadataSummary}" TextWrapping="Wrap"
                                                   FontFamily="Consolas" FontSize="12" Foreground="#4B5565" />
                                    </Expander>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>

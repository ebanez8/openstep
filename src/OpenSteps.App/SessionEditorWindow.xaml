<Window x:Class="OpenSteps.App.SessionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenSteps.App"
        Title="OpenSteps" Width="1120" Height="760" MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <local:FileImageConverter x:Key="FileImageConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1" CornerRadius="20" Padding="24,18" Margin="20,18,20,0">
            <Border.Effect>
                <DropShadowEffect Color="#9DB4BE" BlurRadius="18" ShadowDepth="3" Opacity="0.16" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <DockPanel LastChildFill="True" VerticalAlignment="Center">
                    <TextBox x:Name="SessionTitleBox"
                             FontSize="26" FontWeight="SemiBold"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             ToolTip="Guide title"
                             TextChanged="SessionTitleBox_TextChanged" />
                </DockPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE8A7;" ToolTip="Back to recorder" Click="BackToRecorder_Click"
                            Style="{StaticResource PrimaryIconButton}" />
                    <Button Content="&#xE768;" ToolTip="Record more" Click="RecordMore_Click"
                            Style="{StaticResource IconButton}" Margin="10,0,0,0" />
                    <Button Content="&#xE74E;" ToolTip="Save" Click="SaveSession_Click"
                            Style="{StaticResource IconButton}" Margin="10,0,0,0" />
                    <Button Content="Export" Click="ExportMarkdown_Click"
                            Margin="10,0,0,0" Padding="16,0" Height="34"
                            Style="{StaticResource PrimaryActionButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <Expander Header="Skipped capture events" Margin="0,0,0,14">
                <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="14">
                    <ItemsControl ItemsSource="{Binding SkippedCaptureEvents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplaySummary}"
                                           TextWrapping="Wrap"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,8" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Expander>
            <ItemsControl x:Name="StepsList" ItemsSource="{Binding Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Rectangle Width="2"
                                           Fill="{StaticResource BorderSoftBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Stretch" />
                                <Border Width="42" Height="42"
                                        Background="{StaticResource SoftSurfaceBrush}"
                                        BorderBrush="{StaticResource BorderSoftBrush}"
                                        BorderThickness="1"
                                        CornerRadius="21"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,20,0,0">
                                    <TextBlock Text="{Binding Index}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>

                            <Expander Grid.Column="1" Margin="0,0,0,16" IsExpanded="True">
                                <Expander.Header>
                                    <DockPanel LastChildFill="True" Margin="0,0,0,8">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Index, StringFormat=Step {0}:}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,8,0" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding ActionType}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="12,0,0,0" />
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DockPanel>
                                </Expander.Header>
                                <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1"
                                    CornerRadius="16" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#9DB4BE" BlurRadius="15" ShadowDepth="2" Opacity="0.11" />
                                </Border.Effect>
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="310" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                    <Border Width="280" Height="170" Background="{StaticResource SoftSurfaceBrush}"
                                            BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1"
                                            CornerRadius="14" ClipToBounds="True"
                                            HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Grid>
                                        <Image Source="{Binding EffectiveScreenshotPath, Converter={StaticResource FileImageConverter}}" Stretch="Uniform" />
                                        <TextBlock Text="Redacted"
                                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                                       Margin="8" Padding="8,4" Background="{StaticResource AccentBrush}"
                                                       Foreground="White" FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasRedactions}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Content="&#xE890;" ToolTip="View screenshot" Click="ViewScreenshot_Click"
                                                Style="{StaticResource IconButton}"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Margin="0,0,8,8" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" Margin="12,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="42" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" LastChildFill="True" VerticalAlignment="Center">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Index, StringFormat=Step {0}}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,14,0" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="&#xE70F;" ToolTip="Edit screenshot" Click="EditScreenshot_Click"
                                                    Style="{StaticResource IconButton}" Margin="0,0,6,0" />
                                            <Button Content="&#xE722;" ToolTip="Capture screenshot for this step" Click="CaptureStepScreenshot_Click"
                                                    Style="{StaticResource IconButton}" Margin="0,0,6,0" />
                                            <Button Content="&#xECC8;" ToolTip="Insert manual step below" Click="InsertManualStepBelow_Click"
                                                    Style="{StaticResource IconButton}" Margin="0,0,6,0" />
                                            <Button Content="&#xE74A;" ToolTip="Move up" Click="MoveStepUp_Click"
                                                    Style="{StaticResource IconButton}" Margin="0,0,6,0" />
                                            <Button Content="&#xE74B;" ToolTip="Move down" Click="MoveStepDown_Click"
                                                    Style="{StaticResource IconButton}" Margin="0,0,6,0" />
                                            <Button Content="&#xE74D;" ToolTip="Delete step" Click="DeleteStep_Click"
                                                    Style="{StaticResource IconButton}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding UserTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="StepTextChanged"
                                             Margin="0,8,0,0" FontSize="18" FontWeight="SemiBold" />
                                    <TextBox Grid.Row="2"
                                             Text="{Binding UserDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="StepTextChanged"
                                             Margin="0,10,0,0" MinHeight="72" TextWrapping="Wrap"
                                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />

                                    <Expander Grid.Row="3" Header="Capture debug/status" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding MetadataSummary}" TextWrapping="Wrap"
                                                   FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Expander>
                                </Grid>
                            </Grid>
                        </Border>
                            </Expander>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
